    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-node": "^5.5.3",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.53.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.9",
    "@types/d3": "^7.4.3",
    "@types/eslint": "^9.6.1",
    "@types/nprogress": "^0.2.3",
    "autoprefixer": "^10.4.25",
