{
  "name": "svelte-revolution",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ./build/index.js",
    "start:remote": "node --env-file=.env.prod ./build/index.js",
    "ia": "cd ./ia_server && cargo run",
    "dev": "vite dev",
    "vercel-build": "ADAPTER=auto vite build",
    "build": "ADAPTER=node vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest"
  },
  "peerDependencies": {
    "svelte": "^5.1.9"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.2",
