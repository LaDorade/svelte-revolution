    "@types/sanitize-html": "^2.16.0",
    "bcrypt": "^6.0.0",
    "d3": "^7.9.0",
    "lucide-svelte": "^0.575.0",
    "nprogress": "^0.2.0",
    "pocketbase": "0.26.8",
    "sanitize-html": "^2.17.1",
    "svelte-french-toast": "^1.2.0",
    "svelte-i18n": "^4.0.1",
    "svelte-tweakpane-ui": "^1.5.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
