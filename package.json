{
  "name": "svelte-revolution",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env.production ./build/index.js",
    "ia": "cd ./ia_server && cargo run",
    "dev": "vite dev",
    "vercel-build": "ADAPTER=auto vite build",
    "build": "ADAPTER=node vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "clear-b": "bunx clear-branches",
    "test:unit": "vitest"
  },
  "peerDependencies": {
    "svelte": "^5.1.9"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "@types/sanitize-html": "^2.13.0",
    "bcrypt": "^5.1.1",
    "d3": "^7.9.0",
    "lucide-svelte": "^0.454.0",
    "nprogress": "^0.2.0",
    "pocketbase": "^0.21.5",
    "sanitize-html": "^2.13.1",
    "svelte-french-toast": "^1.2.0",
    "svelte-i18n": "^4.0.1",
    "svelte-tweakpane-ui": "^1.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.49.0",
    "@rollup/plugin-json": "^6.1.0",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/adapter-vercel": "^5.5.0",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/bun": "latest",
    "@types/d3": "^7.4.3",
    "@types/eslint": "^9.6.1",
    "@types/eslint__js": "^8.42.3",
    "@types/nprogress": "^0.2.3",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.14",
    "dotenv": "^16.4.7",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.13.0",
    "playwright": "^1.49.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.6.1",
    "svelte-adapter-bun": "^0.5.2",
    "svelte-check": "^4.1.1",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
